{
  "name": "@customaise/mcp",
  "version": "1.0.3",
  "description": "MCP server that connects AI coding agents (Cursor, Claude Code, Codex, Windsurf, Antigravity) to the Customaise Chrome extension for userscript management and browser automation.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "customaise-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "tsc -p tsconfig.test.json && node --loader ./test-loader.mjs --test test-out/__tests__/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "customaise",
    "userscripts",
    "chrome-extension",
    "browser-automation",
    "model-context-protocol",
    "ai-tools",
    "cursor",
    "claude",
    "windsurf",
    "codex"
  ],
  "author": "Customaise",
  "license": "MIT",
  "homepage": "https://customaise.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getcustomaise/customaise-mcp.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
