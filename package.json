{
  "name": "@customaise/mcp",
  "version": "2.0.2",
  "description": "MCP server bridging AI coding agents (Cursor, Claude Code, Codex, Windsurf, Kiro, Antigravity) to the Customaise Chrome extension. 18 tools: UserScripts, AgentScripts, WebMCP calls with HITL consent, visual DOM targeting, tab control.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "customaise-mcp": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "node --loader ts-node/esm src/index.ts",
    "test": "tsc -p tsconfig.test.json && node --loader ./test-loader.mjs --test test-out/__tests__/*.test.js",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "customaise",
    "userscripts",
    "agentscripts",
    "webmcp",
    "hitl",
    "human-in-the-loop",
    "chrome-extension",
    "browser-automation",
    "model-context-protocol",
    "ai-tools",
    "cursor",
    "claude",
    "windsurf",
    "codex",
    "kiro",
    "antigravity"
  ],
  "author": "CNDLE Studio LTD",
  "license": "MIT",
  "homepage": "https://customaise.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/getcustomaise/customaise-mcp.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.26.0",
    "sharp": "^0.34.5",
    "ws": "^8.18.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/sharp": "^0.31.1",
    "@types/ws": "^8.5.0",
    "ts-node": "^10.9.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vitest": "^4.1.0"
  }
}
